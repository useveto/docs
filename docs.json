{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "luma",
  "name": "Veto",
  "logo": {
    "light": "/images/logo-light.svg",
    "dark": "/images/logo-dark.svg"
  },
  "favicon": "/favicon.svg",
  "colors": {
    "primary": "#14bc84"
  },
  "openapi": [
    "openapi.yml"
  ],
  "api": {
    "playground": {
      "display": "interactive"
    }
  },
  "feedback": {
    "thumbsRating": true
  },
  "navbar": {
    "links": [
      {
        "label": "Dashboard",
        "href": "https://app.veto.tools"
      }
    ],
    "primary": {
      "type": "github",
      "href": "https://github.com/useveto/docs"
    }
  },
  "anchors": [
    {
      "anchor": "Status",
      "icon": "signal",
      "href": "https://status.veto.tools"
    }
  ],
  "footer": {
    "socials": {
      "github": "https://github.com/useveto",
      "website": "https://veto.tools"
    }
  },
  "navigation": {
    "tabs": [
      {
        "tab": "Docs",
        "groups": [
          {
            "group": "Get Started",
            "pages": [
              "introduction",
              "quickstart",
              "authentication"
            ]
          },
          {
            "group": "Core Concepts",
            "pages": [
              "concepts/agents",
              "concepts/policies",
              "concepts/rules",
              "concepts/audit-log"
            ]
          },
          {
            "group": "Integrations",
            "pages": [
              "integrations/node-sdk",
              "integrations/python-sdk",
              "integrations/mcp"
            ]
          },
          {
            "group": "Dashboard",
            "pages": [
              "dashboard/overview",
              "dashboard/api-keys"
            ]
          }
        ]
      },
      {
        "tab": "API Reference",
        "groups": [
          {
            "group": "Overview",
            "pages": [
              "api-reference/overview",
              "api-reference/errors"
            ]
          },
          {
            "group": "Authorization",
            "pages": [
              "POST /v1/authorize"
            ]
          },
          {
            "group": "Agents",
            "pages": [
              "POST /v1/agents",
              "GET /v1/agents",
              "GET /v1/agents/{id}",
              "PATCH /v1/agents/{id}",
              "DELETE /v1/agents/{id}"
            ]
          },
          {
            "group": "Policies",
            "pages": [
              "POST /v1/policies",
              "GET /v1/policies",
              "GET /v1/policies/{id}",
              "PATCH /v1/policies/{id}",
              "DELETE /v1/policies/{id}"
            ]
          },
          {
            "group": "Audit Logs",
            "pages": [
              "GET /v1/audit-logs",
              "GET /v1/audit-logs/export"
            ]
          },
          {
            "group": "API Keys",
            "pages": [
              "POST /v1/api-keys",
              "GET /v1/api-keys",
              "DELETE /v1/api-keys/{id}"
            ]
          }
        ]
      }
    ]
  }
}